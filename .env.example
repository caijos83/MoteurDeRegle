# Copier ce fichier en .env et adapter selon votre configuration locale
# Le fichier .env n'est pas versionné (voir .gitignore)

API_BASE_URL=http://localhost:8000/api/v1

# Ports (optionnel, valeurs par défaut ci-dessous)
API_PORT=8000
UI_PORT=8501

# Navigateur (optionnel — détecté automatiquement si absent)
# BROWSER_PATH=/usr/bin/google-chrome
