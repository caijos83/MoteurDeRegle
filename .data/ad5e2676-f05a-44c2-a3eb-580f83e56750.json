{
  "id": "ad5e2676-f05a-44c2-a3eb-580f83e56750",
  "name": "EligibiliteCredit",
  "hit_policy": "FIRST",
  "columns": [
    {
      "name": "age",
      "type": "number",
      "role": "input"
    },
    {
      "name": "revenu",
      "type": "number",
      "role": "input"
    },
    {
      "name": "decision",
      "type": "text",
      "role": "output"
    }
  ],
  "rules": [
    {
      "conditions": {
        "age": "< 18"
      },
      "output": {
        "decision": "REFUSE"
      }
    },
    {
      "conditions": {
        "age": ">= 18",
        "revenu": ">= 2000"
      },
      "output": {
        "decision": "ACCEPTE"
      }
    },
    {
      "conditions": {
        "age": ">= 18",
        "revenu": "< 2000"
      },
      "output": {
        "decision": "DOSSIER_INCOMPLET"
      }
    }
  ]
}